{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        { "source": "/((?!api|_next|assets).*)", "destination": "/index.html" }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(.*).mp4",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
                { "key": "Accept-Ranges", "value": "bytes" }
            ]
        },
        {
            "source": "/(.*).jpg",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ]
}